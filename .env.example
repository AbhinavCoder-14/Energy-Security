# Aegis Energy Security — environment template (copy to `.env` in project root)
# Never commit real secrets.

# --- Mode ---
# LIVE = production pipeline (OpenRouter + live Brent + strict news parse)
# SIMULATION = scenarios.json safety net (hackathon / demo)
APP_MODE=SIMULATION

# Legacy alias: AEGIS_DEMO_MODE=1 maps to SIMULATION
# AEGIS_DEMO_MODE=1

PORT=8000
ENVIRONMENT=development

# --- LLM via OpenRouter (required for LIVE Agent 1 & 3) ---
OPEN_ROUTER_API=sk-or-v1-your-openrouter-key-here
# Also accepts: OPENROUTER_API_KEY
LLM_MODEL=google/gemini-2.5-flash

# --- News (at least one for LIVE Agent 1) ---
# newsdata.io (key usually starts with pub_)
NEWSDATA_API_KEY=pub_your-newsdata-key-here
# OR NewsAPI.org
# NEWSAPI_ORG_KEY=your-newsapi-org-key

# Legacy name still supported:
# NEWSAPI_KEY=pub_your-newsdata-key-here

# --- Market data (optional; yfinance BZ=F used if missing) ---
OILPRICE_API_KEY=your-oilpriceapi-key-here

# --- Structural baselines (Agent 2 math) ---
INDIA_ISPRL_CAPACITY_MB=39.0
INDIA_COMMERCIAL_BUFFER_MB=322.5
INDIA_TOTAL_DAILY_IMPORT_MBPD=5.0
GLOBAL_DAILY_OIL_SUPPLY_MBPD=102.5

# --- Agent 2 formula constants (optional overrides) ---
# BASE_FREIGHT_USD=3.00
# CAPE_MILES=12000
# SUEZ_MILES=7200
# SCARCITY_MULTIPLIER=12.5
# WAR_RISK_COEFF=0.025

# --- Corporate SSL (many laptops need this) ---
AEGIS_SSL_VERIFY=0

# --- Frontend (optional) ---
# NEXT_PUBLIC_API_BASE=http://localhost:8000
# NEXT_PUBLIC_FORCE_MOCK=1
